{
  "name": "msim-debugger",
  "publisher": "0xVector",
  "displayName": "MSIM debugger",
  "description": "MSIM emulator debugging support via DAP",
  "version": "0.0.1",
  "repository": "https://github.com/0xVector/msim-debugger",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Debuggers",
    "Education"
  ],
  "activationEvents": [
    "onDebug:msim",
    "onDebugResolve:msim"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "debuggers": [
      {
        "type": "msim",
        "label": "MSIM Debugger",
        "languages": [
          "c"
        ],
        "configurationAttributes": {
          "attach": {
            "properties": {
              "msimPath": {
                "type": "string",
                "description": "Path to the MSIM binary. Defaults to 'msim' (resolved from PATH).",
                "default": "msim"
              },
              "port": {
                "type": "number",
                "description": "Port MSIM listens on for DAP connections.",
                "default": 10505
              },
              "kernelPath": {
                "type": "string",
                "description": "Path to the kernel.raw file (or other ELF file) to debug. Relative paths are resolved from the workspace root. Defaults to './kernel/kernel.raw'.",
                "default": "./kernel/kernel.raw"
              }
            },
            "additionalProperties": false
          }
        },
        "initialConfigurations": [
          {
            "name": "MSIM debug default config",
            "type": "msim",
            "request": "attach",
            "msimPath": "msim",
            "port": 10505,
            "kernelPath": "./kernel/kernel.raw"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "msim-debugger.activate",
        "title": "Activate MSIM DAP Debugger"
      }
    ],
    "breakpoints": [
      {
        "language": "c",
        "when": "debugType == msim"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.105.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.36.0",
    "typescript": "^5.9.3"
  }
}
